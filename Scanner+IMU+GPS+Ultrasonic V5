#include <TinyGPS++.h>
#include "VideoStream.h"
#include "AmebaFatFS.h"
#include <Wire.h>

// GPS
TinyGPSPlus gps;

// Camera
#define CHANNEL 2
VideoSetting config(VIDEO_FHD, CAM_FPS, VIDEO_JPEG, 1);
uint32_t img_addr = 0;
uint32_t img_len = 0;

// SD card
AmebaFatFS fs;

// HC-SR04 ultrasonic sensor
#define TRIG_PIN 6
#define ECHO_PIN 7

// RGB LED indicator
#define LED_RED_PIN  3
#define LED_BLUE_PIN 4
bool firstGPSWritten = false;
unsigned long lastFlash = 0;
bool ledState = false;

// BNO055 registers
const uint8_t BNO055_ADDR        = 0x28;
const uint8_t BNO055_CHIP_ID     = 0x00;
const uint8_t BNO055_OPR_MODE    = 0x3D;
const uint8_t BNO055_SYS_TRIGGER = 0x3F;
const uint8_t BNO055_SYS_STATUS  = 0x39;
const uint8_t BNO055_SYS_ERR     = 0x3A;
const uint8_t BNO055_CALIB_STAT  = 0x35;
const uint8_t BNO055_MAG_X       = 0x0E;  // Mag + Gyro: 12 bytes (0x0E-0x19)
const uint8_t BNO055_QUAT_W      = 0x20;  // Quat + LinAccel + Gravity: 20 bytes (0x20-0x33)
const uint8_t BNO055_MODE_NDOF   = 0x0C;
const uint8_t BNO055_MODE_CONFIG = 0x00;

bool imuReady = false;

// --- Sample struct ---

struct Sample {
  uint32_t ms;
  // IMU
  float ax, ay, az;
  float gvx, gvy, gvz;
  float gx, gy, gz;
  float qw, qx, qy, qz;
  float mx, my, mz;
  uint8_t calSys, calGyro, calAccel, calMag;
  // Ultrasonic
  uint16_t dist_mm;
  // GPS (only valid when hasGPS is true)
  bool hasGPS;
  double lat, lng, alt, speed, hdg, hdop;
  int sats;
  // UTC timestamp from GPS (valid when hasGPS is true)
  uint16_t year;
  uint8_t month, day, hour, minute, second, centisecond;
};

// RAM buffer: 25Hz × 5s = 125 samples, with headroom
const int MAX_SAMPLES = 140;
Sample sampleBuf[MAX_SAMPLES];
int sampleCount = 0;
uint32_t totalSamples = 0;
uint32_t imuFailCount = 0;

// Timing
unsigned long lastSample = 0;
unsigned long lastWaypoint = 0;
const unsigned long sampleInterval = 40;     // 40ms = 25Hz
const unsigned long waypointInterval = 5000; // 5 seconds
int waypoint = 0;

// GPS state
bool hasFix = false;
bool newGPSFix = false;
double gpsLat = 0, gpsLng = 0, gpsAlt = 0;
double gpsSpeed = 0, gpsHdg = 0, gpsHdop = 0;
int gpsSats = 0;
uint16_t gpsYear = 0;
uint8_t gpsMonth = 0, gpsDay = 0, gpsHour = 0, gpsMinute = 0, gpsSecond = 0, gpsCentisecond = 0;


// --- BNO055 helper functions ---

void bno055_writeReg(uint8_t reg, uint8_t val) {
  Wire.beginTransmission(BNO055_ADDR);
  Wire.write(reg);
  Wire.write(val);
  Wire.endTransmission();
  delay(10);
}

uint8_t bno055_readReg(uint8_t reg) {
  Wire.beginTransmission(BNO055_ADDR);
  Wire.write(reg);
  Wire.endTransmission();
  Wire.requestFrom(BNO055_ADDR, (uint8_t)1);
  return Wire.available() ? Wire.read() : 0xFF;
}

bool bno055_readBytes(uint8_t reg, uint8_t *buf, uint8_t len) {
  Wire.beginTransmission(BNO055_ADDR);
  Wire.write(reg);
  int err = Wire.endTransmission();
  if (err != 0) return false;
  Wire.requestFrom(BNO055_ADDR, len);
  for (uint8_t i = 0; i < len; i++) {
    if (!Wire.available()) return false;
    buf[i] = Wire.read();
  }
  return true;
}

bool bno055_init() {
  uint8_t id = bno055_readReg(BNO055_CHIP_ID);
  Serial.print("BNO055 chip ID: 0x");
  Serial.println(id, HEX);
  if (id != 0xA0) return false;

  bno055_writeReg(BNO055_OPR_MODE, BNO055_MODE_CONFIG);
  delay(50);

  bno055_writeReg(BNO055_SYS_TRIGGER, 0x20);
  delay(1000);

  for (int i = 0; i < 30; i++) {
    delay(100);
    id = bno055_readReg(BNO055_CHIP_ID);
    if (id == 0xA0) break;
  }
  if (id != 0xA0) return false;

  delay(500);

  uint8_t mode = 0;
  for (int attempt = 0; attempt < 5; attempt++) {
    bno055_writeReg(BNO055_OPR_MODE, BNO055_MODE_NDOF);
    delay(200);
    mode = bno055_readReg(BNO055_OPR_MODE);
    Serial.print("NDOF attempt "); Serial.print(attempt);
    Serial.print(": OPR_MODE=0x"); Serial.println(mode, HEX);
    if (mode == BNO055_MODE_NDOF) break;
    delay(500);
  }

  if (mode != BNO055_MODE_NDOF) {
    Serial.println("FAIL: Could not enter NDOF mode.");
    return false;
  }

  delay(200);
  uint8_t status = bno055_readReg(BNO055_SYS_STATUS);
  uint8_t err = bno055_readReg(BNO055_SYS_ERR);
  Serial.print("SYS_STATUS: 0x"); Serial.println(status, HEX);
  Serial.print("SYS_ERR: 0x"); Serial.println(err, HEX);

  return true;
}


// --- Sensor read: individual 6-byte reads (proven pattern from v2) ---

bool readSensors(Sample &s) {
  uint8_t buf[8];  // Reused for each read

  // Magnetometer: 0x0E, 6 bytes
  if (!bno055_readBytes(0x0E, buf, 6)) return false;
  s.mx = (int16_t)(buf[0] | (buf[1] << 8)) / 16.0;
  s.my = (int16_t)(buf[2] | (buf[3] << 8)) / 16.0;
  s.mz = (int16_t)(buf[4] | (buf[5] << 8)) / 16.0;

  delay(3);

  // Gyroscope: 0x14, 6 bytes
  if (!bno055_readBytes(0x14, buf, 6)) return false;
  s.gx = (int16_t)(buf[0] | (buf[1] << 8)) / 900.0;
  s.gy = (int16_t)(buf[2] | (buf[3] << 8)) / 900.0;
  s.gz = (int16_t)(buf[4] | (buf[5] << 8)) / 900.0;

  delay(3);

  // Quaternion: 0x20, 8 bytes
  if (!bno055_readBytes(0x20, buf, 8)) return false;
  s.qw = (int16_t)(buf[0] | (buf[1] << 8)) / 16384.0;
  s.qx = (int16_t)(buf[2] | (buf[3] << 8)) / 16384.0;
  s.qy = (int16_t)(buf[4] | (buf[5] << 8)) / 16384.0;
  s.qz = (int16_t)(buf[6] | (buf[7] << 8)) / 16384.0;

  delay(3);

  // Linear acceleration: 0x28, 6 bytes
  if (!bno055_readBytes(0x28, buf, 6)) return false;
  s.ax = (int16_t)(buf[0] | (buf[1] << 8)) / 100.0;
  s.ay = (int16_t)(buf[2] | (buf[3] << 8)) / 100.0;
  s.az = (int16_t)(buf[4] | (buf[5] << 8)) / 100.0;

  delay(3);

  // Gravity: 0x2E, 6 bytes
  if (!bno055_readBytes(0x2E, buf, 6)) return false;
  s.gvx = (int16_t)(buf[0] | (buf[1] << 8)) / 100.0;
  s.gvy = (int16_t)(buf[2] | (buf[3] << 8)) / 100.0;
  s.gvz = (int16_t)(buf[4] | (buf[5] << 8)) / 100.0;

  delay(3);

  // Calibration: 0x35, 1 byte
  uint8_t cal = bno055_readReg(BNO055_CALIB_STAT);
  if (cal == 0xFF) return false;
  s.calSys   = (cal >> 6) & 0x03;
  s.calGyro  = (cal >> 4) & 0x03;
  s.calAccel = (cal >> 2) & 0x03;
  s.calMag   = cal & 0x03;

  return true;
}


// --- HC-SR04 ultrasonic read ---

uint16_t readUltrasonic() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);

  unsigned long duration = pulseIn(ECHO_PIN, HIGH, 30000);  // 30ms timeout (~5m max)
  if (duration == 0) return 0;  // No echo / timeout

  return (uint16_t)(duration * 0.343 / 2.0);  // Convert to mm
}


// --- Flush sample buffer to SD ---

void flushSamplesToSD() {
  if (sampleCount == 0) return;

  unsigned long t0 = millis();

  File f = fs.open(String("trail_data.csv"));
  if (!f) {
    Serial.println("ERROR: Failed to open trail_data.csv");
    return;
  }
  f.seek(f.size());

  // Write rows in small batches to avoid one giant string
  char row[256];
  char ts[32];
  for (int i = 0; i < sampleCount; i++) {
    Sample &s = sampleBuf[i];

    if (s.hasGPS) {
      sprintf(ts, "%04d-%02d-%02dT%02d:%02d:%02d.%02d",
        s.year, s.month, s.day,
        s.hour, s.minute, s.second, s.centisecond);
      sprintf(row,
        "%lu,%s,%d,"
        "%.2f,%.2f,%.2f,"
        "%.2f,%.2f,%.2f,"
        "%.4f,%.4f,%.4f,"
        "%.4f,%.4f,%.4f,%.4f,"
        "%.1f,%.1f,%.1f,"
        "%u,"
        "%.6f,%.6f,%.1f,%.1f,%.1f,%d,%.1f,"
        "%d,%d,%d,%d",
        s.ms, ts, waypoint,
        s.ax, s.ay, s.az,
        s.gvx, s.gvy, s.gvz,
        s.gx, s.gy, s.gz,
        s.qw, s.qx, s.qy, s.qz,
        s.mx, s.my, s.mz,
        s.dist_mm,
        s.lat, s.lng, s.alt, s.speed, s.hdg, s.sats, s.hdop,
        s.calSys, s.calGyro, s.calAccel, s.calMag);
    } else {
      sprintf(row,
        "%lu,,%d,"
        "%.2f,%.2f,%.2f,"
        "%.2f,%.2f,%.2f,"
        "%.4f,%.4f,%.4f,"
        "%.4f,%.4f,%.4f,%.4f,"
        "%.1f,%.1f,%.1f,"
        "%u,"
        ",,,,,,,"
        "%d,%d,%d,%d",
        s.ms, waypoint,
        s.ax, s.ay, s.az,
        s.gvx, s.gvy, s.gvz,
        s.gx, s.gy, s.gz,
        s.qw, s.qx, s.qy, s.qz,
        s.mx, s.my, s.mz,
        s.dist_mm,
        s.calSys, s.calGyro, s.calAccel, s.calMag);
    }

    f.println(row);
  }

  f.close();

  unsigned long elapsed = millis() - t0;
  Serial.print("Flushed "); Serial.print(sampleCount);
  Serial.print(" rows in "); Serial.print(elapsed); Serial.println("ms");
}


// --- Main ---

void setup() {
  Serial.begin(115200);
  delay(3000);
  Serial1.begin(9600);
  Serial.println("Trail Scanner v5 — 25Hz single CSV, RAM buffered, Ultrasonic + LED");

  // Init LED pins
  pinMode(LED_RED_PIN, OUTPUT);
  pinMode(LED_BLUE_PIN, OUTPUT);
  digitalWrite(LED_RED_PIN, HIGH);   // Start with red ON
  digitalWrite(LED_BLUE_PIN, LOW);
  ledState = true;

  // Init ultrasonic sensor pins
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  digitalWrite(TRIG_PIN, LOW);
  Serial.println("HC-SR04 pins ready.");

  // Init camera
  Camera.configVideoChannel(CHANNEL, config);
  Camera.videoInit();
  Camera.channelBegin(CHANNEL);
  Serial.println("Camera ready.");

  // Init I2C (BNO055)
  Wire.begin();
  delay(100);

  // Init IMU
  if (bno055_init()) {
    imuReady = true;
    Serial.println("BNO055 ready.");
    Serial.println("Waiting 3 seconds for sensor to settle...");
    delay(3000);
  } else {
    Serial.println("WARNING: BNO055 not detected — continuing without IMU.");
  }

  // Init SD card
  if (!fs.begin()) {
    Serial.println("ERROR: SD card failed to mount.");
    while (1);
  }
  Serial.println("SD card ready.");

  // Clean slate
  fs.remove("trail_data.csv");
  fs.mkdir("jpg");

  // Write CSV header
  File f = fs.open(String("trail_data.csv"));
  if (f) {
    f.println(
      "ms,utc,wp,"
      "ax,ay,az,"
      "gvx,gvy,gvz,"
      "gx,gy,gz,"
      "qw,qx,qy,qz,"
      "mx,my,mz,"
      "dist_mm,"
      "lat,lng,alt,speed,hdg,sats,hdop,"
      "cal_sys,cal_gyro,cal_accel,cal_mag"
    );
    f.close();
    Serial.println("Wrote trail_data.csv header.");
  }

  waypoint = 0;
  sampleCount = 0;
  totalSamples = 0;
  imuFailCount = 0;

  Serial.println("Waiting for GPS fix...");
  lastSample = millis();
  lastWaypoint = millis();
  lastFlash = millis();
}

void loop() {
  unsigned long now = millis();

  // --- LED indicator ---
  if (!firstGPSWritten) {
    // Flash red at ~1Hz (500ms on, 500ms off)
    if (now - lastFlash >= 500) {
      lastFlash = now;
      ledState = !ledState;
      digitalWrite(LED_RED_PIN, ledState ? HIGH : LOW);
    }
  }

  // --- Feed GPS (non-blocking) ---
  while (Serial1.available()) {
    if (gps.encode(Serial1.read())) {
      if (gps.location.isUpdated()) {
        newGPSFix = true;
        hasFix = true;
        gpsLat = gps.location.lat();
        gpsLng = gps.location.lng();
        gpsAlt = gps.altitude.meters();
        gpsSpeed = gps.speed.kmph();
        gpsHdg = gps.course.deg();
        gpsSats = gps.satellites.value();
        gpsHdop = gps.hdop.hdop();
        if (gps.date.isValid() && gps.time.isValid()) {
          gpsYear = gps.date.year();
          gpsMonth = gps.date.month();
          gpsDay = gps.date.day();
          gpsHour = gps.time.hour();
          gpsMinute = gps.time.minute();
          gpsSecond = gps.time.second();
          gpsCentisecond = gps.time.centisecond();
        }
      }
    }
  }

  // --- 25Hz sensor sample into RAM buffer ---
  if (imuReady && (now - lastSample >= sampleInterval)) {
    lastSample = now;

    if (sampleCount < MAX_SAMPLES) {
      Sample &s = sampleBuf[sampleCount];
      s.ms = now;

      if (readSensors(s)) {
        // Read ultrasonic distance
        s.dist_mm = readUltrasonic();

        // Attach GPS if we have a fresh fix
        if (newGPSFix) {
          s.hasGPS = true;
          s.lat = gpsLat;
          s.lng = gpsLng;
          s.alt = gpsAlt;
          s.speed = gpsSpeed;
          s.hdg = gpsHdg;
          s.sats = gpsSats;
          s.hdop = gpsHdop;
          s.year = gpsYear;
          s.month = gpsMonth;
          s.day = gpsDay;
          s.hour = gpsHour;
          s.minute = gpsMinute;
          s.second = gpsSecond;
          s.centisecond = gpsCentisecond;
          newGPSFix = false;
        } else {
          s.hasGPS = false;
        }

        sampleCount++;
        totalSamples++;
      } else {
        imuFailCount++;
      }
    }
  }

  // --- Waypoint: flush to SD + capture image ---
  if (now - lastWaypoint >= waypointInterval) {

    if (!hasFix) {
      lastWaypoint = now;
      Serial.print("No GPS fix yet. Satellites: ");
      Serial.println(gps.satellites.value());
      // Don't reset buffer — keep accumulating until we get a fix
      return;
    }

    // Flush sensor buffer to SD
    flushSamplesToSD();

    // Switch LED from flashing red to solid blue on first GPS write
    if (!firstGPSWritten) {
      firstGPSWritten = true;
      digitalWrite(LED_RED_PIN, LOW);
      digitalWrite(LED_BLUE_PIN, HIGH);
      Serial.println("LED: switched to solid blue (GPS data written).");
    }

    // Capture JPEG
    unsigned long camStart = millis();
    Camera.getImage(CHANNEL, &img_addr, &img_len);

    if (img_len > 0) {
      char jpgPath[40];
      sprintf(jpgPath, "jpg/img_%04d.jpg", waypoint);

      File jpgFile = fs.open(String(jpgPath));
      if (jpgFile) {
        jpgFile.write((uint8_t*)img_addr, img_len);
        jpgFile.close();
      }
    }
    unsigned long camElapsed = millis() - camStart;

    // Serial status
    Serial.println("=== Waypoint ===");
    Serial.print("WP: "); Serial.print(waypoint);
    Serial.print("  Samples: "); Serial.print(sampleCount);
    Serial.print("  Total: "); Serial.print(totalSamples);
    Serial.print("  Failures: "); Serial.println(imuFailCount);
    Serial.print("Lat: "); Serial.print(gpsLat, 6);
    Serial.print("  Lng: "); Serial.println(gpsLng, 6);
    Serial.print("Sats: "); Serial.print(gpsSats);
    Serial.print("  HDOP: "); Serial.println(gpsHdop, 1);
    Serial.print("Dist: "); Serial.print(readUltrasonic());
    Serial.println("mm");
    if (img_len > 0) {
      Serial.print("Image: img_"); Serial.print(waypoint);
      Serial.print(" ("); Serial.print(img_len);
      Serial.print(" bytes, "); Serial.print(camElapsed); Serial.println("ms)");
    } else {
      Serial.println("Camera capture failed.");
    }
    Serial.println("================");

    waypoint++;
    sampleCount = 0;  // Reset buffer for next interval

    // Restart timers AFTER all I/O so next interval gets full 5 seconds
    lastWaypoint = millis();
    lastSample = millis();
  }
}
