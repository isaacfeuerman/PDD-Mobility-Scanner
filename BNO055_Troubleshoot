#include <Wire.h>

// BNO055 registers
const uint8_t BNO055_ADDR    = 0x28;
const uint8_t BNO055_ADDR_ALT = 0x29;
const uint8_t BNO055_CHIP_ID = 0x00;

// Verify a device is real by trying to read a byte from it
bool verifyDevice(uint8_t addr) {
  Wire.beginTransmission(addr);
  int err = Wire.endTransmission();
  if (err != 0) return false;
  delay(2);
  Wire.requestFrom(addr, (uint8_t)1);
  return Wire.available() > 0;
}

void scanBus() {
  Serial.println("--- I2C Bus Scan ---");
  int found = 0;
  for (uint8_t addr = 1; addr < 127; addr++) {
    if (verifyDevice(addr)) {
      Serial.print("  Device at 0x");
      if (addr < 16) Serial.print("0");
      Serial.print(addr, HEX);
      if (addr == BNO055_ADDR) Serial.print("  <-- BNO055 (ADR low)");
      if (addr == BNO055_ADDR_ALT) Serial.print("  <-- BNO055 (ADR high)");
      Serial.println();
      found++;
    }
    delay(2);
  }
  if (found == 0) {
    Serial.println("  NO devices found.");
    Serial.println();
    Serial.println("Check wiring:");
    Serial.println("  SDA -> pin 9 (D9)");
    Serial.println("  SCL -> pin 10 (D10)");
    Serial.println("  VIN -> 3.3V");
    Serial.println("  GND -> GND");
  } else {
    Serial.print(found);
    Serial.println(" device(s) found.");
  }
  Serial.println();
}

void checkBNO055(uint8_t addr) {
  Wire.beginTransmission(addr);
  Wire.write(BNO055_CHIP_ID);
  int err = Wire.endTransmission();
  if (err != 0) {
    Serial.print("  0x"); Serial.print(addr, HEX);
    Serial.print(" -> No response (error "); Serial.print(err); Serial.println(")");
    return;
  }
  Wire.requestFrom(addr, (uint8_t)1);
  if (Wire.available()) {
    uint8_t id = Wire.read();
    Serial.print("  0x"); Serial.print(addr, HEX);
    Serial.print(" -> Chip ID: 0x"); Serial.print(id, HEX);
    if (id == 0xA0) {
      Serial.println("  BNO055 confirmed!");

      // Read status registers
      Serial.println();
      Serial.println("--- BNO055 Status ---");
      uint8_t regs[] = {0x01, 0x02, 0x03, 0x39, 0x3A, 0x3D, 0x35};
      const char* names[] = {"ACC_ID", "MAG_ID", "GYR_ID", "SYS_STATUS", "SYS_ERR", "OPR_MODE", "CALIB_STAT"};
      for (int r = 0; r < 7; r++) {
        Wire.beginTransmission(addr);
        Wire.write(regs[r]);
        Wire.endTransmission();
        Wire.requestFrom(addr, (uint8_t)1);
        if (Wire.available()) {
          uint8_t val = Wire.read();
          Serial.print("  "); Serial.print(names[r]);
          Serial.print(": 0x"); Serial.println(val, HEX);
        }
      }
      Serial.println();
      Serial.println("Expected: ACC=0xFB MAG=0x32 GYR=0x0F");
      Serial.println("CALIB 0xFF = fully calibrated");
    } else {
      Serial.println("  Not a BNO055 (expected 0xA0)");
    }
  }
}

void setup() {
  Serial.begin(115200);
  delay(3000);
  Serial.println("=== BNO055 Troubleshooter v2 ===");
  Serial.println("Uses read-back verify to filter ghost devices");
  Serial.println();

  Wire.begin();
  delay(100);

  scanBus();

  Serial.println("--- BNO055 Chip ID Check ---");
  checkBNO055(BNO055_ADDR);
  checkBNO055(BNO055_ADDR_ALT);

  Serial.println();
  Serial.println("=== Done. Re-scans every 10s ===");
}

void loop() {
  delay(10000);
  Serial.println();
  scanBus();
}
