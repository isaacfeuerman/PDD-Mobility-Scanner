#include <TinyGPS++.h>
#include "VideoStream.h"
#include "StreamIO.h"
#include "MP4Recording.h"
#include "AmebaFatFS.h"
#include <Wire.h>
#include <VL53L1X.h>

// GPS
TinyGPSPlus gps;

// Video recording (H.264 → MP4 on SD)
#define VIDEO_CHANNEL 0
VideoSetting configV(VIDEO_FHD, 1, VIDEO_H264, 0);  // 1 FPS H.264
MP4Recording mp4;
StreamIO videoStreamer(1, 1);  // camera → MP4 pipeline
uint32_t recStartMs = 0;

// SD card
AmebaFatFS fs;

// ToF sensor
VL53L1X tof;
bool tofReady = false;

// Button — external button, S pin to pin 19, - pin to GND
#define BTN_PIN 19
bool recording = false;
bool btnWasPressed = false;

// Session management
int sessionNum = 0;
char csvPath[40];

// BNO055 registers
const uint8_t BNO055_ADDR        = 0x28;
const uint8_t BNO055_CHIP_ID     = 0x00;
const uint8_t BNO055_OPR_MODE    = 0x3D;
const uint8_t BNO055_SYS_TRIGGER = 0x3F;
const uint8_t BNO055_SYS_STATUS  = 0x39;
const uint8_t BNO055_SYS_ERR     = 0x3A;
const uint8_t BNO055_CALIB_STAT  = 0x35;
const uint8_t BNO055_MAG_X       = 0x0E;
const uint8_t BNO055_QUAT_W      = 0x20;
const uint8_t BNO055_MODE_NDOF   = 0x0C;
const uint8_t BNO055_MODE_CONFIG = 0x00;

bool imuReady = false;

// --- Sample struct ---

struct Sample {
  uint32_t ms;
  float ax, ay, az;
  float gvx, gvy, gvz;
  float gx, gy, gz;
  float qw, qx, qy, qz;
  float mx, my, mz;
  uint8_t calSys, calGyro, calAccel, calMag;
  bool hasToF;
  uint16_t tof_mm;
  uint8_t tof_status;
  bool hasGPS;
  double lat, lng, alt, speed, hdg, hdop;
  int sats;
  uint16_t year;
  uint8_t month, day, hour, minute, second, centisecond;
};

const int MAX_SAMPLES = 140;
Sample sampleBuf[MAX_SAMPLES];
int sampleCount = 0;
uint32_t totalSamples = 0;
uint32_t imuFailCount = 0;

// Timing
unsigned long lastSample = 0;
unsigned long lastFlush = 0;
const unsigned long sampleInterval = 40;     // 40ms = 25Hz
const unsigned long flushInterval = 5000;    // flush RAM buffer to SD every 5s

// GPS state
bool hasFix = false;
bool newGPSFix = false;
double gpsLat = 0, gpsLng = 0, gpsAlt = 0;
double gpsSpeed = 0, gpsHdg = 0, gpsHdop = 0;
int gpsSats = 0;
uint16_t gpsYear = 0;
uint8_t gpsMonth = 0, gpsDay = 0, gpsHour = 0, gpsMinute = 0, gpsSecond = 0, gpsCentisecond = 0;


// --- BNO055 helper functions ---

void bno055_writeReg(uint8_t reg, uint8_t val) {
  Wire.beginTransmission(BNO055_ADDR);
  Wire.write(reg);
  Wire.write(val);
  Wire.endTransmission();
  delay(10);
}

uint8_t bno055_readReg(uint8_t reg) {
  Wire.beginTransmission(BNO055_ADDR);
  Wire.write(reg);
  Wire.endTransmission();
  Wire.requestFrom(BNO055_ADDR, (uint8_t)1);
  return Wire.available() ? Wire.read() : 0xFF;
}

bool bno055_readBytes(uint8_t reg, uint8_t *buf, uint8_t len) {
  Wire.beginTransmission(BNO055_ADDR);
  Wire.write(reg);
  int err = Wire.endTransmission();
  if (err != 0) return false;
  Wire.requestFrom(BNO055_ADDR, len);
  for (uint8_t i = 0; i < len; i++) {
    if (!Wire.available()) return false;
    buf[i] = Wire.read();
  }
  return true;
}

bool bno055_init() {
  uint8_t id = bno055_readReg(BNO055_CHIP_ID);
  Serial.print("BNO055 chip ID: 0x");
  Serial.println(id, HEX);
  if (id != 0xA0) return false;

  bno055_writeReg(BNO055_OPR_MODE, BNO055_MODE_CONFIG);
  delay(50);

  bno055_writeReg(BNO055_SYS_TRIGGER, 0x20);
  delay(1000);

  for (int i = 0; i < 30; i++) {
    delay(100);
    id = bno055_readReg(BNO055_CHIP_ID);
    if (id == 0xA0) break;
  }
  if (id != 0xA0) return false;

  delay(500);

  uint8_t mode = 0;
  for (int attempt = 0; attempt < 5; attempt++) {
    bno055_writeReg(BNO055_OPR_MODE, BNO055_MODE_NDOF);
    delay(200);
    mode = bno055_readReg(BNO055_OPR_MODE);
    Serial.print("NDOF attempt "); Serial.print(attempt);
    Serial.print(": OPR_MODE=0x"); Serial.println(mode, HEX);
    if (mode == BNO055_MODE_NDOF) break;
    delay(500);
  }

  if (mode != BNO055_MODE_NDOF) {
    Serial.println("FAIL: Could not enter NDOF mode.");
    return false;
  }

  delay(200);
  uint8_t status = bno055_readReg(BNO055_SYS_STATUS);
  uint8_t err = bno055_readReg(BNO055_SYS_ERR);
  Serial.print("SYS_STATUS: 0x"); Serial.println(status, HEX);
  Serial.print("SYS_ERR: 0x"); Serial.println(err, HEX);

  return true;
}


// --- Sensor read ---

bool readSensors(Sample &s) {
  uint8_t buf[8];

  if (!bno055_readBytes(0x0E, buf, 6)) return false;
  s.mx = (int16_t)(buf[0] | (buf[1] << 8)) / 16.0;
  s.my = (int16_t)(buf[2] | (buf[3] << 8)) / 16.0;
  s.mz = (int16_t)(buf[4] | (buf[5] << 8)) / 16.0;
  delay(3);

  if (!bno055_readBytes(0x14, buf, 6)) return false;
  s.gx = (int16_t)(buf[0] | (buf[1] << 8)) / 900.0;
  s.gy = (int16_t)(buf[2] | (buf[3] << 8)) / 900.0;
  s.gz = (int16_t)(buf[4] | (buf[5] << 8)) / 900.0;
  delay(3);

  if (!bno055_readBytes(0x20, buf, 8)) return false;
  s.qw = (int16_t)(buf[0] | (buf[1] << 8)) / 16384.0;
  s.qx = (int16_t)(buf[2] | (buf[3] << 8)) / 16384.0;
  s.qy = (int16_t)(buf[4] | (buf[5] << 8)) / 16384.0;
  s.qz = (int16_t)(buf[6] | (buf[7] << 8)) / 16384.0;
  delay(3);

  if (!bno055_readBytes(0x28, buf, 6)) return false;
  s.ax = (int16_t)(buf[0] | (buf[1] << 8)) / 100.0;
  s.ay = (int16_t)(buf[2] | (buf[3] << 8)) / 100.0;
  s.az = (int16_t)(buf[4] | (buf[5] << 8)) / 100.0;
  delay(3);

  if (!bno055_readBytes(0x2E, buf, 6)) return false;
  s.gvx = (int16_t)(buf[0] | (buf[1] << 8)) / 100.0;
  s.gvy = (int16_t)(buf[2] | (buf[3] << 8)) / 100.0;
  s.gvz = (int16_t)(buf[4] | (buf[5] << 8)) / 100.0;
  delay(3);

  uint8_t cal = bno055_readReg(BNO055_CALIB_STAT);
  if (cal == 0xFF) return false;
  s.calSys   = (cal >> 6) & 0x03;
  s.calGyro  = (cal >> 4) & 0x03;
  s.calAccel = (cal >> 2) & 0x03;
  s.calMag   = cal & 0x03;

  return true;
}


// --- Flush sample buffer to SD ---

void flushSamplesToSD() {
  if (sampleCount == 0) return;

  unsigned long t0 = millis();

  File f = fs.open(String(csvPath));
  if (!f) {
    Serial.print("ERROR: Failed to open "); Serial.println(csvPath);
    return;
  }
  f.seek(f.size());

  char row[256];
  char ts[32];
  for (int i = 0; i < sampleCount; i++) {
    Sample &s = sampleBuf[i];

    char tofStr[16];
    if (s.hasToF) {
      sprintf(tofStr, "%u,%u", s.tof_mm, s.tof_status);
    } else {
      strcpy(tofStr, ",");
    }

    if (s.hasGPS) {
      sprintf(ts, "%04d-%02d-%02dT%02d:%02d:%02d.%02d",
        s.year, s.month, s.day,
        s.hour, s.minute, s.second, s.centisecond);
      sprintf(row,
        "%lu,%s,"
        "%.2f,%.2f,%.2f,"
        "%.2f,%.2f,%.2f,"
        "%.4f,%.4f,%.4f,"
        "%.4f,%.4f,%.4f,%.4f,"
        "%.1f,%.1f,%.1f,"
        "%s,"
        "%.6f,%.6f,%.1f,%.1f,%.1f,%d,%.1f,"
        "%d,%d,%d,%d",
        s.ms, ts,
        s.ax, s.ay, s.az,
        s.gvx, s.gvy, s.gvz,
        s.gx, s.gy, s.gz,
        s.qw, s.qx, s.qy, s.qz,
        s.mx, s.my, s.mz,
        tofStr,
        s.lat, s.lng, s.alt, s.speed, s.hdg, s.sats, s.hdop,
        s.calSys, s.calGyro, s.calAccel, s.calMag);
    } else {
      sprintf(row,
        "%lu,,"
        "%.2f,%.2f,%.2f,"
        "%.2f,%.2f,%.2f,"
        "%.4f,%.4f,%.4f,"
        "%.4f,%.4f,%.4f,%.4f,"
        "%.1f,%.1f,%.1f,"
        "%s,"
        ",,,,,,,"
        "%d,%d,%d,%d",
        s.ms,
        s.ax, s.ay, s.az,
        s.gvx, s.gvy, s.gvz,
        s.gx, s.gy, s.gz,
        s.qw, s.qx, s.qy, s.qz,
        s.mx, s.my, s.mz,
        tofStr,
        s.calSys, s.calGyro, s.calAccel, s.calMag);
    }

    f.println(row);
  }

  f.close();

  unsigned long elapsed = millis() - t0;
  Serial.print("Flushed "); Serial.print(sampleCount);
  Serial.print(" rows in "); Serial.print(elapsed); Serial.println("ms");
}


// --- Session start/stop ---

void startSession() {
  char sessionDir[20];
  char mp4Name[40];

  sprintf(sessionDir, "session_%02d", sessionNum);
  sprintf(csvPath, "%s/trail_data.csv", sessionDir);
  sprintf(mp4Name, "%s/trail_video", sessionDir);

  // Create session directory
  fs.mkdir(sessionDir);
  Serial.print("=== Starting session "); Serial.print(sessionNum);
  Serial.print(" ("); Serial.print(sessionDir); Serial.println(") ===");

  // Start MP4 recording
  mp4.configVideo(configV);
  mp4.setRecordingDuration(3600);
  mp4.setRecordingFileCount(1);
  mp4.setRecordingFileName(mp4Name);
  mp4.setRecordingDataType(STORAGE_VIDEO);

  videoStreamer.registerInput(Camera.getStream(VIDEO_CHANNEL));
  videoStreamer.registerOutput(mp4);
  if (videoStreamer.begin() != 0) {
    Serial.println("ERROR: StreamIO link failed.");
  }
  Camera.channelBegin(VIDEO_CHANNEL);
  mp4.begin();
  recStartMs = millis();

  // Write CSV header with rec_start_ms
  File f = fs.open(String(csvPath));
  if (f) {
    char meta[40];
    sprintf(meta, "# rec_start_ms=%lu", recStartMs);
    f.println(meta);
    f.println(
      "ms,utc,"
      "ax,ay,az,"
      "gvx,gvy,gvz,"
      "gx,gy,gz,"
      "qw,qx,qy,qz,"
      "mx,my,mz,"
      "tof_mm,tof_status,"
      "lat,lng,alt,speed,hdg,sats,hdop,"
      "cal_sys,cal_gyro,cal_accel,cal_mag"
    );
    f.close();
  }

  sampleCount = 0;
  totalSamples = 0;
  imuFailCount = 0;
  lastSample = millis();
  lastFlush = millis();
  recording = true;

  Serial.println("Recording. Press button to stop.");
}

void stopSession() {
  flushSamplesToSD();
  mp4.end();
  recording = false;

  Serial.print("=== Session "); Serial.print(sessionNum);
  Serial.println(" stopped. MP4 finalized. ===");
  Serial.println("Safe to remove power, or press button for next session.");

  sessionNum++;
}


// --- Main ---

void setup() {
  Serial.begin(115200);
  delay(3000);
  Serial1.begin(9600);
  Serial.println("Trail Scanner v4 — 25Hz CSV, ToF, 1FPS MP4, multi-session");

  pinMode(BTN_PIN, INPUT_PULLUP);

  // Init camera
  Camera.configVideoChannel(VIDEO_CHANNEL, configV);
  Camera.videoInit();
  Serial.println("Camera initialized.");

  // Init I2C
  Wire.begin();
  delay(100);

  // Init IMU
  if (bno055_init()) {
    imuReady = true;
    Serial.println("BNO055 ready.");
    delay(3000);
  } else {
    Serial.println("WARNING: BNO055 not detected.");
  }

  // Init ToF
  tof.setTimeout(500);
  if (tof.init()) {
    tof.setDistanceMode(VL53L1X::Long);
    tof.setMeasurementTimingBudget(33000);
    tof.startContinuous(40);
    tofReady = true;
    Serial.println("VL53L1X ready.");
  } else {
    Serial.println("WARNING: VL53L1X not detected.");
  }

  // Init SD
  if (!fs.begin()) {
    Serial.println("ERROR: SD card failed to mount.");
    while (1);
  }
  Serial.println("SD card ready.");

  // Start first session
  startSession();
}

void loop() {
  unsigned long now = millis();

  // --- Button toggle: stop/start sessions ---
  bool btnPressed = (digitalRead(BTN_PIN) == LOW);

  if (btnPressed && !btnWasPressed) {
    delay(50);  // debounce
    if (digitalRead(BTN_PIN) == LOW) {
      if (recording) {
        stopSession();
      } else {
        startSession();
      }
    }
  }
  btnWasPressed = btnPressed;

  // --- Feed GPS (non-blocking) ---
  while (Serial1.available()) {
    if (gps.encode(Serial1.read())) {
      if (gps.location.isUpdated()) {
        newGPSFix = true;
        hasFix = true;
        gpsLat = gps.location.lat();
        gpsLng = gps.location.lng();
        gpsAlt = gps.altitude.meters();
        gpsSpeed = gps.speed.kmph();
        gpsHdg = gps.course.deg();
        gpsSats = gps.satellites.value();
        gpsHdop = gps.hdop.hdop();
        if (gps.date.isValid() && gps.time.isValid()) {
          gpsYear = gps.date.year();
          gpsMonth = gps.date.month();
          gpsDay = gps.date.day();
          gpsHour = gps.time.hour();
          gpsMinute = gps.time.minute();
          gpsSecond = gps.time.second();
          gpsCentisecond = gps.time.centisecond();
        }
      }
    }
  }

  if (!recording) return;  // skip sampling when stopped

  // --- 25Hz sensor sample into RAM buffer ---
  if (imuReady && (now - lastSample >= sampleInterval)) {
    lastSample = now;

    if (sampleCount < MAX_SAMPLES) {
      Sample &s = sampleBuf[sampleCount];
      s.ms = now;

      if (readSensors(s)) {
        if (tofReady && tof.dataReady()) {
          s.tof_mm = tof.read(false);
          s.tof_status = tof.ranging_data.range_status;
          s.hasToF = true;
        } else {
          s.hasToF = false;
        }

        if (newGPSFix) {
          s.hasGPS = true;
          s.lat = gpsLat;
          s.lng = gpsLng;
          s.alt = gpsAlt;
          s.speed = gpsSpeed;
          s.hdg = gpsHdg;
          s.sats = gpsSats;
          s.hdop = gpsHdop;
          s.year = gpsYear;
          s.month = gpsMonth;
          s.day = gpsDay;
          s.hour = gpsHour;
          s.minute = gpsMinute;
          s.second = gpsSecond;
          s.centisecond = gpsCentisecond;
          newGPSFix = false;
        } else {
          s.hasGPS = false;
        }

        sampleCount++;
        totalSamples++;
      } else {
        imuFailCount++;
      }
    }
  }

  // --- Periodic flush ---
  if (now - lastFlush >= flushInterval) {

    flushSamplesToSD();

    unsigned long vidSec = (millis() - recStartMs) / 1000;
    Serial.print("["); Serial.print(sessionNum); Serial.print("] ");
    Serial.print("Total: "); Serial.print(totalSamples);
    Serial.print("  Failures: "); Serial.print(imuFailCount);
    Serial.print("  Video: "); Serial.print(vidSec); Serial.print("s");
    if (hasFix) {
      Serial.print("  Lat: "); Serial.print(gpsLat, 6);
      Serial.print("  Lng: "); Serial.print(gpsLng, 6);
      Serial.print("  Sats: "); Serial.print(gpsSats);
    } else {
      Serial.print("  No GPS fix (sats: "); Serial.print(gps.satellites.value()); Serial.print(")");
    }
    if (tofReady) {
      Serial.print("  ToF: "); Serial.print(tof.ranging_data.range_mm); Serial.print("mm");
    }
    Serial.println();

    sampleCount = 0;
    lastFlush = millis();
    lastSample = millis();
  }
}
