#include "VideoStream.h"
#include "StreamIO.h"
#include "MP4Recording.h"
#include "AmebaFatFS.h"

// Video recording
#define VIDEO_CHANNEL 0
VideoSetting configV(VIDEO_FHD, 5, VIDEO_H264, 0);  // 5 FPS H.264
MP4Recording mp4;
StreamIO videoStreamer(1, 1);

// SD card
AmebaFatFS fs;

// Stop button (BOOT button on AMB82 Mini)
#define STOP_BTN_PIN 1
bool recording = false;

void setup() {
  Serial.begin(115200);
  delay(3000);
  Serial.println("=== Video Record Test ===");

  // Stop button
  pinMode(STOP_BTN_PIN, INPUT_PULLUP);

  // Init SD card first
  if (!fs.begin()) {
    Serial.println("ERROR: SD card failed to mount.");
    while (1);
  }
  Serial.println("SD card ready.");

  // Init camera
  Camera.configVideoChannel(VIDEO_CHANNEL, configV);
  Camera.videoInit();
  Serial.println("Camera initialized.");

  // Set up MP4 recording
  mp4.configVideo(configV);
  mp4.setRecordingFileName("test_video");
  mp4.setRecordingDuration(60);  // 60 seconds for testing

  // Wire camera → MP4
  videoStreamer.registerInput(Camera.getStream(VIDEO_CHANNEL));
  videoStreamer.registerOutput(mp4);
  if (videoStreamer.begin() != 0) {
    Serial.println("ERROR: StreamIO link failed.");
    while (1);
  }
  Serial.println("StreamIO linked.");

  // Start recording
  Camera.channelBegin(VIDEO_CHANNEL);
  mp4.begin();
  recording = true;
  Serial.println("Recording started. Press BOOT button to stop.");
}

void loop() {
  if (!recording) return;

  // Check stop button
  if (digitalRead(STOP_BTN_PIN) == LOW) {
    delay(50);  // debounce
    if (digitalRead(STOP_BTN_PIN) == LOW) {
      Serial.println("STOP button pressed...");

      mp4.end();
      Serial.println("MP4 finalized.");

      recording = false;
      Serial.println("Recording stopped. Safe to remove power or SD card.");

      while (1) {
        delay(1000);
      }
    }
  }

  // Print a heartbeat every 5 seconds so we know it's alive
  static unsigned long lastPrint = 0;
  if (millis() - lastPrint >= 5000) {
    lastPrint = millis();
    Serial.print("Recording... ");
    Serial.print(millis() / 1000);
    Serial.println("s");
  }
}
