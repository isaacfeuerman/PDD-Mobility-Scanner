#include "StreamIO.h"
#include "VideoStream.h"
#include "MP4Recording.h"

#define CHANNEL 0

// Use default preset for channel 0 (1920x1080 30FPS H264)
VideoSetting config(CHANNEL);
MP4Recording mp4;
StreamIO videoStreamer(1, 1);

// Stop button — BOOT button on AMB82 Mini
#define STOP_BTN_PIN PF_13
bool recording = false;

void setup() {
  Serial.begin(115200);
  delay(3000);
  Serial.println("=== Video Record Test ===");

  // Stop button (has external pull-high on board, reads LOW when pressed)
  pinMode(STOP_BTN_PIN, INPUT);

  // Configure camera video channel
  Camera.configVideoChannel(CHANNEL, config);
  Camera.videoInit();

  // Configure MP4 recording
  mp4.configVideo(config);
  mp4.setRecordingDuration(60);
  mp4.setRecordingFileCount(1);
  mp4.setRecordingFileName("test_video");
  mp4.setRecordingDataType(STORAGE_VIDEO);

  // Wire camera → MP4
  videoStreamer.registerInput(Camera.getStream(CHANNEL));
  videoStreamer.registerOutput(mp4);
  if (videoStreamer.begin() != 0) {
    Serial.println("StreamIO link start failed");
    while (1);
  }
  Serial.println("StreamIO linked.");

  // Start recording
  Camera.channelBegin(CHANNEL);
  mp4.begin();
  recording = true;

  delay(1000);
  Serial.println("Recording started. Press BOOT button or send serial to stop.");
  Camera.printInfo();
  mp4.printInfo();
}

void loop() {
  if (!recording) return;

  // Check stop button (S1 / BOOT — reads LOW when pressed)
  bool stopPressed = false;
  if (digitalRead(STOP_BTN_PIN) == LOW) {
    delay(50);  // debounce
    if (digitalRead(STOP_BTN_PIN) == LOW) stopPressed = true;
  }

  // Also check serial as fallback
  if (Serial.available()) {
    while (Serial.available()) Serial.read();
    stopPressed = true;
  }

  if (stopPressed) {
    Serial.println("Stop command received...");
    mp4.end();
    Serial.println("MP4 finalized.");

    recording = false;
    Serial.println("Recording stopped. Safe to remove power or SD card.");

    while (1) {
      delay(1000);
    }
  }

  // Heartbeat every 5 seconds
  static unsigned long lastPrint = 0;
  if (millis() - lastPrint >= 5000) {
    lastPrint = millis();
    Serial.print("Recording... ");
    Serial.print(millis() / 1000);
    Serial.println("s");
  }
}
